{
  "name": "iquantum",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "iquantum-daemon",
    "iquantum-cli"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "cd iquantum-daemon && bun run dev",
    "test": "vitest run",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "zod": "latest"
  }
}
