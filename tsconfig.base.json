{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@iquantum/types": ["packages/types/src/index.ts"],
      "@iquantum/config": ["packages/config/src/index.ts"],
      "@iquantum/repo-map": ["packages/repo-map/src/index.ts"]
    }
  }
}
