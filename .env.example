# iquantum daemon configuration
# Copy to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Anthropic API key (required for the default Anthropic provider)
ANTHROPIC_API_KEY=sk-ant-...

# To use an OpenAI-compatible provider (e.g. DeepSeek):
# IQUANTUM_PROVIDER=openai
# IQUANTUM_BASE_URL=https://api.deepseek.com
# IQUANTUM_API_KEY=sk-...
# IQUANTUM_ARCHITECT_MODEL=deepseek-reasoner
# IQUANTUM_EDITOR_MODEL=deepseek-chat

# Model for the Plan phase — use a reasoning-capable model
IQUANTUM_ARCHITECT_MODEL=claude-sonnet-4-6

# Model for the Implement phase — use a fast, cheap model
IQUANTUM_EDITOR_MODEL=claude-haiku-4-5-20251001

# Unix socket path for daemon ↔ CLI communication
IQUANTUM_SOCKET=~/.iquantum/daemon.sock

# Optional localhost TCP port for VS Code ↔ daemon communication
# IQUANTUM_TCP_PORT=51820

# Optional browser origins allowed to call the cloud TCP API. Leave unset for no browser CORS access.
# IQUANTUM_CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Maximum retry attempts across plan rejections, diff failures, and validation failures
MAX_RETRIES=3

# Maximum duration for a sandbox command before the container is killed
IQUANTUM_EXEC_TIMEOUT_MS=120000

# === Memory ===
# Memory is materialized into ~/.iquantum/MEMORY.md and injected within this token budget.
IQUANTUM_MEMORY_TOKENS=2000
# Enable automatic memory extraction from conversations.
# IQUANTUM_AUTO_MEMORY=false

# === Built-in tools ===
# Built-in file tools are enabled by default. Set false to disable file_read/edit/write/glob/grep.
IQUANTUM_FILE_TOOLS=true
# Maximum bytes returned by one file tool read.
IQUANTUM_FILE_TOOL_MAX_BYTES=200000

# Sandbox container image pulled from GHCR automatically on first use
# Override for local development (after docker build -t iquantum/sandbox:local ...):
#   IQUANTUM_SANDBOX_IMAGE=iquantum/sandbox:local
IQUANTUM_SANDBOX_IMAGE=ghcr.io/ayhamjo7/iquantum-sandbox:latest

# MCP servers to expose as tools (optional, JSON array)
# Each entry: { "name": "label", "command": "executable", "args": [...], "env": {...} }
# Example: [{"name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/workspace"]}]
IQUANTUM_MCP_SERVERS=[]

# Built-in web tools are opt-in. Brave is the default provider; Tavily is also supported.
# IQUANTUM_WEB_TOOLS=true
# IQUANTUM_SEARCH_PROVIDER=brave
# BRAVE_API_KEY= 
# TAVILY_API_KEY= 

# === Extensibility ===
# Hooks are hot-loaded from this directory. Shell hooks receive event JSON on stdin.
IQUANTUM_HOOKS_DIR=~/.iquantum/hooks
IQUANTUM_HOOK_TIMEOUT_MS=5000
# Skills are hot-loaded as slash commands from this directory.
IQUANTUM_SKILLS_DIR=~/.iquantum/skills
# Custom REPL chord bindings.
IQUANTUM_KEYBINDINGS_FILE=~/.iquantum/keybindings.json

# Optional model override for iq review.
# IQUANTUM_REVIEW_MODEL=claude-sonnet-4-6

# Optional Sentry DSN for production error tracking.
# SENTRY_DSN=https://public@example.ingest.sentry.io/1

# === Cloud tier (optional) ===
# IQUANTUM_CLOUD=false
# DATABASE_URL=postgresql://iquantum:devpassword@localhost:5432/iquantum
# REDIS_URL=redis://localhost:6379  # required in cloud mode for auth rate limiting
# JWT_SECRET=replace-with-at-least-32-characters
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# AWS_REGION=eu-central-1
# AWS_ECS_CLUSTER=iquantum
# AWS_EFS_FILE_SYSTEM_ID=fs-...
# AWS_SUBNET_IDS=subnet-abc123,subnet-def456
# AWS_SECURITY_GROUP_IDS=sg-abc123
# AWS_ASSIGN_PUBLIC_IP=false
